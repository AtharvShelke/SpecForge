generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────

enum Category {
  PROCESSOR
  GPU
  MOTHERBOARD
  RAM
  STORAGE
  PSU
  CABINET
  COOLER
  MONITOR
  PERIPHERAL
  NETWORKING
  LAPTOP
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum CompatibilityLevel {
  COMPATIBLE
  WARNING
  INCOMPATIBLE
}

enum StockMovementType {
  PURCHASE
  INWARD
  OUTWARD
  SALE
  RETURN
  ADJUSTMENT
  RESERVE
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
  VOIDED
}

enum InvoiceType {
  STANDARD
  CREDIT_NOTE
}

enum SalesChannel {
  ONLINE
  POS
  MANUAL
  API
  PHONE
}

enum PaymentMethodType {
  CARD
  UPI
  BANK_TRANSFER
  CASH
  WALLET
}

enum PaymentStatus {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PurchaseOrderStatus {
  PENDING
  PARTIAL
  COMPLETED
  CANCELLED
}

enum InventoryUnitStatus {
  AVAILABLE
  RESERVED
  SOLD
  RETURNED
  LOST
  DAMAGED
}

enum Currency {
  INR
  USD
  EUR
  GBP
}

enum FilterType {
  checkbox
  range
  boolean
  search
  dropdown
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  WAREHOUSE_STAFF
  FINANCE
  USER
}

// ─────────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────
// CATALOG — Brand
// ─────────────────────────────────────────────────

model Brand {
  id         String     @id @default(uuid())
  name       String     @unique
  categories Category[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  products   Product[]
}

// ─────────────────────────────────────────────────
// CATALOG — Category Hierarchy & Schema
// ─────────────────────────────────────────────────

model CategoryHierarchy {
  id        String              @id @default(uuid())
  label     String
  category  Category?
  query     String?
  brand     String?
  parentId  String?
  sortOrder Int                 @default(0)
  parent    CategoryHierarchy?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  CategoryHierarchy[] @relation("CategoryTree")

  @@index([parentId])
  @@index([sortOrder])
  @@index([category])
}

model CategorySchema {
  id         String                @id @default(uuid())
  category   Category              @unique
  attributes AttributeDefinition[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

model AttributeDefinition {
  id               String         @id @default(uuid())
  key              String
  label            String
  type             String
  required         Boolean        @default(false)
  options          String[]
  unit             String?
  categorySchemaId String
  dependencyKey    String?
  dependencyValue  String?
  sortOrder        Int            @default(0)
  categorySchema   CategorySchema @relation(fields: [categorySchemaId], references: [id], onDelete: Cascade)

  @@unique([categorySchemaId, key])
}

model CategoryFilterConfig {
  id        String             @id @default(uuid())
  category  Category           @unique
  filters   FilterDefinition[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model FilterDefinition {
  id                     String               @id @default(uuid())
  key                    String
  label                  String
  type                   FilterType
  options                String[]
  min                    Float?
  max                    Float?
  dependencyKey          String?
  dependencyValue        String?
  sortOrder              Int                  @default(0)
  categoryFilterConfigId String
  categoryFilterConfig   CategoryFilterConfig @relation(fields: [categoryFilterConfigId], references: [id], onDelete: Cascade)

  @@unique([categoryFilterConfigId, key])
  @@index([categoryFilterConfigId])
  @@index([categoryFilterConfigId, sortOrder])
}

// ─────────────────────────────────────────────────
// CATALOG — Product, Variants, Media, Tags
// ─────────────────────────────────────────────────

model Tag {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[] // Implicit m:n
}

model ProductMedia {
  id        String  @id @default(uuid())
  productId String
  url       String
  altText   String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sortOrder])
  @@index([productId, sortOrder])
}

model Product {
  id              String        @id @default(uuid())
  slug            String        @unique @default(uuid())
  name            String
  metaTitle       String?
  metaDescription String?
  category        Category
  description     String?
  status          ProductStatus @default(ACTIVE)
  deletedAt       DateTime?
  version         Int           @default(1)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specs    ProductSpec[]
  variants ProductVariant[]
  media    ProductMedia[]
  tags     Tag[]

  @@index([status])
  @@index([category])
  @@index([brandId])
  @@index([slug])
  @@index([name])
  @@index([status, category])
  @@index([status, name])
}

model ProductVariant {
  id             String    @id @default(uuid())
  productId      String
  sku            String    @unique
  price          Float
  compareAtPrice Float?
  attributes     Json?
  status         String    @default("IN_STOCK")
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product              Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseInventories WarehouseInventory[]
  orderItems           OrderItem[]
  buildGuideItems      BuildGuideItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  inventoryUnits       InventoryUnit[]

  @@index([productId])
  @@index([sku])
  @@index([price])
  @@index([status])
  @@index([productId, status])
  @@index([productId, price])
}

model ProductSpec {
  id        String  @id @default(uuid())
  productId String
  key       String
  value     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([key, value])
  @@index([productId, key])
}

// ─────────────────────────────────────────────────
// WAREHOUSING & INVENTORY
// ─────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventories    WarehouseInventory[]
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
  inventoryUnits InventoryUnit[]
}

model WarehouseInventory {
  id           String    @id @default(uuid())
  variantId    String
  warehouseId  String
  quantity     Int       @default(0)
  reserved     Int       @default(0)
  reorderLevel Int       @default(5)
  costPrice    Float     @default(0)
  location     String    @default("")
  lastUpdated  DateTime?

  variant        ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]
  inventoryUnits InventoryUnit[]

  @@unique([variantId, warehouseId])
  @@index([quantity])
  @@index([warehouseId])
  @@index([variantId])
  @@index([lastUpdated])
}

model StockMovement {
  id                   String            @id @default(uuid())
  warehouseInventoryId String
  warehouseId          String
  type                 StockMovementType
  quantity             Int
  previousQuantity     Int               @default(0)
  newQuantity          Int               @default(0)
  reason               String?
  performedBy          String            @default("System")
  orderId              String?
  purchaseOrderId      String?
  vendorId             String?
  inventoryUnitId      String?
  serialNumberSnapshot String?
  createdAt            DateTime          @default(now())

  warehouseInventory WarehouseInventory @relation(fields: [warehouseInventoryId], references: [id], onDelete: Cascade)
  warehouse          Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  order              Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  purchaseOrder      PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  vendor             Supplier?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  inventoryUnit      InventoryUnit?     @relation(fields: [inventoryUnitId], references: [id], onDelete: SetNull)

  @@index([warehouseInventoryId, createdAt])
  @@index([warehouseId])
  @@index([type])
  @@index([orderId])
  @@index([purchaseOrderId])
  @@index([vendorId])
  @@index([inventoryUnitId])
  @@index([createdAt])
}

model InventoryUnit {
  id                   String              @id @default(uuid())
  variantId            String
  warehouseId          String
  sn                   String?             @unique
  imei                 String?             @unique
  status               InventoryUnitStatus @default(AVAILABLE)
  orderItemId          String?
  purchaseOrderItemId  String?
  warehouseInventoryId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  soldAt    DateTime?

  variant            ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Restrict)
  warehouse          Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  warehouseInventory WarehouseInventory? @relation(fields: [warehouseInventoryId], references: [id], onDelete: Cascade)
  orderItem          OrderItem?          @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  purchaseOrderItem  PurchaseOrderItem?  @relation(fields: [purchaseOrderItemId], references: [id], onDelete: SetNull)
  stockMovements     StockMovement[]

  @@index([variantId])
  @@index([warehouseId])
  @@index([status])
  @@index([orderItemId])
  @@index([purchaseOrderItemId])
  @@index([warehouseInventoryId])
}

// ─────────────────────────────────────────────────
// SUPPLIERS & PURCHASE ORDERS
// ─────────────────────────────────────────────────

model Supplier {
  id        String   @id @default(uuid())
  name      String   @unique
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  stockMovements StockMovement[]
}

model PurchaseOrder {
  id               String              @id @default(uuid())
  supplierId       String
  warehouseId      String
  status           PurchaseOrderStatus @default(PENDING)
  expectedDelivery DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  supplier       Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  warehouse      Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  items          PurchaseOrderItem[]
  stockMovements StockMovement[]

  @@index([supplierId])
  @@index([warehouseId])
}

model PurchaseOrderItem {
  id               String @id @default(uuid())
  purchaseOrderId  String
  variantId        String
  quantityOrdered  Int
  quantityReceived Int    @default(0)
  unitCost         Float

  purchaseOrder  PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant        ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  inventoryUnits InventoryUnit[]

  @@index([purchaseOrderId])
  @@index([variantId])
}

// ─────────────────────────────────────────────────
// CUSTOMER (Guest — no auth)
// ─────────────────────────────────────────────────

model Customer {
  id           String  @id @default(uuid())
  name         String
  email        String
  phone        String?
  company      String?
  addressLine1 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
  orders   Order[]
  lead     Lead?

  @@index([email])
  @@index([name])
}

// ─────────────────────────────────────────────────
// ORDERS & SHIPMENTS
// ─────────────────────────────────────────────────

model Order {
  id             String       @id
  channel        SalesChannel @default(ONLINE)
  customerName   String
  email          String
  phone          String?
  date           DateTime     @default(now())
  subtotal       Float        @default(0)
  gstAmount      Float        @default(0)
  taxAmount      Float        @default(0)
  discountAmount Float        @default(0)
  total          Float
  status         OrderStatus  @default(PENDING)
  version        Int          @default(1)
  deletedAt      DateTime?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  shippingStreet  String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?

  paymentMethod        String?
  paymentTransactionId String?
  paymentStatus        String?
  idempotencyKey       String? @unique
  source               Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      OrderItem[]
  logs       OrderLog[]
  invoices   Invoice[]
  shipments  ShipmentTracking[]
  payments   PaymentTransaction[]
  stockMoves StockMovement[]

  @@index([email])
  @@index([status])
  @@index([date])
  @@index([status, date])
  @@index([channel])
  @@index([customerId])
}

model OrderItem {
  id                   String   @id @default(uuid())
  orderId              String
  variantId            String
  name                 String
  category             Category
  price                Float
  quantity             Int
  image                String?
  sku                  String?
  serialNumberSnapshot String?
  partNumberSnapshot   String?
  variantSnapshot      Json? // Immutable record of variant traits at time of purchase

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant        ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  inventoryUnits InventoryUnit[]

  @@index([orderId])
  @@index([variantId])
}

model OrderLog {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  timestamp DateTime    @default(now())
  note      String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, timestamp])
}

model ShipmentTracking {
  id                String    @id @default(uuid())
  orderId           String
  trackingNumber    String
  carrier           String
  status            String
  estimatedDelivery DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─────────────────────────────────────────────────
// BUILD GUIDES
// ─────────────────────────────────────────────────

model BuildGuide {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String   @default("General") // e.g., Gaming, Workstation
  total       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items BuildGuideItem[]

  @@index([createdAt])
}

model BuildGuideItem {
  id           String @id @default(uuid())
  buildGuideId String
  variantId    String
  quantity     Int    @default(1)

  buildGuide BuildGuide     @relation(fields: [buildGuideId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([buildGuideId, variantId])
  @@index([buildGuideId])
}

// ─────────────────────────────────────────────────
// BILLING & INVOICES
// ─────────────────────────────────────────────────

model InvoiceSequence {
  id           String @id @default("invoice_seq")
  currentValue Int    @default(0)
}

model BillingProfile {
  id           String   @id @default(uuid())
  companyName  String
  legalName    String?
  email        String
  phone        String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String
  gstin        String?
  currency     Currency @default(INR)
  logoUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  orderId       String?
  type          InvoiceType   @default(STANDARD)
  status        InvoiceStatus @default(DRAFT)
  customerId    String
  currency      Currency      @default(INR)

  subtotal    Float @default(0)
  taxTotal    Float @default(0)
  discountPct Float @default(0)
  shipping    Float @default(0)
  total       Float @default(0)
  amountPaid  Float @default(0)
  amountDue   Float @default(0)

  notes       String?
  sentAt      DateTime?
  refundedAt  DateTime?
  cancelledAt DateTime?
  paidAt      DateTime?
  voidedAt    DateTime?

  createdAt     DateTime @default(now())
  dueDate       DateTime
  lastUpdatedAt DateTime @updatedAt

  order       Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer    Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lineItems   InvoiceLineItem[]
  audit       InvoiceAuditEvent[]
  creditNotes CreditNote[]

  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  name        String
  description String?
  quantity    Int
  unitPrice   Float
  taxRatePct  Float   @default(18)
  hsnCode     String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceAuditEvent {
  id        String   @id @default(uuid())
  invoiceId String
  type      String
  actor     String
  message   String?
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
}

// ─────────────────────────────────────────────────
// PAYMENT TRANSACTIONS
// ─────────────────────────────────────────────────

model PaymentTransaction {
  id             String            @id @default(uuid())
  orderId        String
  method         PaymentMethodType
  gatewayTxnId   String?           @unique
  amount         Float
  currency       Currency          @default(INR)
  status         PaymentStatus     @default(INITIATED)
  idempotencyKey String            @unique
  metadata       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

// ─────────────────────────────────────────────────
// CREDIT NOTES (Refund Invoices)
// ─────────────────────────────────────────────────

model CreditNote {
  id                String  @id @default(uuid())
  creditNoteNumber  String  @unique
  originalInvoiceId String
  orderId           String?
  reason            String
  subtotal          Float
  taxTotal          Float
  total             Float

  createdAt DateTime @default(now())

  originalInvoice Invoice              @relation(fields: [originalInvoiceId], references: [id], onDelete: Restrict)
  lineItems       CreditNoteLineItem[]

  @@index([originalInvoiceId])
  @@index([orderId])
}

model CreditNoteLineItem {
  id           String  @id @default(uuid())
  creditNoteId String
  name         String
  quantity     Int
  unitPrice    Float
  taxRatePct   Float   @default(18)
  hsnCode      String?

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}

// ─────────────────────────────────────────────────
// UNIFIED AUDIT LOG
// ─────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  actor      String   @default("System")
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actor])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────
// MARKETING & LEADS
// ─────────────────────────────────────────────────

// Represents a potential or existing customer entering a funnel
model Lead {
  id     String  @id @default(uuid())
  email  String  @unique
  name   String?
  source String? // e.g., "Footer Newsletter", "Exit Popup"

  // Link to a full Customer if they eventually convert/create an account
  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  unsubscribed Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events MarketingEvent[]
  logs   EmailLog[]

  @@index([email])
}

enum MarketingEventType {
  PAGE_VIEW
  CART_VISIT
  CART_ABANDONED
  CHECKOUT_STARTED
  PRODUCT_VIEWED
  CUSTOM
  NEWSLETTER_SIGNUP
}

// Immutable ledger of actions taken by a Lead
model MarketingEvent {
  id        String             @id @default(uuid())
  leadId    String
  type      MarketingEventType
  metadata  Json? // e.g., { "cartId": "123", "value": 150.00 }
  createdAt DateTime           @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([type, createdAt])
}

// Defines an automated sequence of rules
model MarketingCampaign {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  isActive    Boolean            @default(false)
  triggerType MarketingEventType // What starts the campaign

  // JSON defining the logic, e.g., 
  // { delayHours: 2, condition: "cart_value > 50", templateId: "abandoned_cart_1" }
  rulesConfig Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailLogs EmailLog[]
}

// Record of emails sent to prevent duplicates and track delivery
model EmailLog {
  id         String  @id @default(uuid())
  leadId     String
  campaignId String?

  subject String
  status  String   @default("SENT") // SENT, DELIVERED, BOUNCED, OPENED
  sentAt  DateTime @default(now())

  lead     Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([leadId, campaignId])
  @@index([sentAt])
}
