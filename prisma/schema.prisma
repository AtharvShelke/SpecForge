// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum CompatibilityLevel {
  COMPATIBLE
  WARNING
  INCOMPATIBLE
}

enum StockMovementType {
  PURCHASE
  INWARD
  OUTWARD
  SALE
  RETURN
  ADJUSTMENT
  RESERVE
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
  VOIDED
}

enum InvoiceType {
  STANDARD
  CREDIT_NOTE
}

enum SalesChannel {
  ONLINE
  POS
  MANUAL
  API
  PHONE
}

enum PaymentMethodType {
  UPI
  BANK_TRANSFER
  RAZORPAY
}

enum PaymentStatus {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum Currency {
  INR
  USD
  EUR
  GBP
}

enum FilterType {
  checkbox
  range
  boolean
  search
  dropdown
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum Role {
  ADMIN
  USER
}

// ─────────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────
// CATALOG — Category & Brand
// ─────────────────────────────────────────────────

model Category {
  id                   Int      @id @default(autoincrement())
  name                 String   @unique @db.VarChar(100)
  slug                 String   @unique @db.VarChar(100)
  description          String?  @db.Text
  image                String?  @db.VarChar(500)
  isActive             Boolean  @default(true) @map("is_active")
  categoryDefinitionId String?  @map("category_definition_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  subcategories       Subcategory[]
  products            Product[]
  brandCategories     BrandCategory[]
  orderItems          OrderItem[]
  buildGuides         BuildGuide[]
  categoryDefinition  CategoryDefinition? @relation(fields: [categoryDefinitionId], references: [id], onDelete: SetNull)

  @@index([categoryDefinitionId])
  @@map("categories")
}

model Subcategory {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  image       String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([slug])
  @@map("subcategories")
}

// Explicit join table for Brand <-> Category (many-to-many)
model BrandCategory {
  brandId    String
  categoryId Int

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([brandId, categoryId])
  @@map("brand_categories")
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products        Product[]
  brandCategories BrandCategory[]
}

// ─────────────────────────────────────────────────
// CATALOG — Category Hierarchy & Schema
// ─────────────────────────────────────────────────

model CategoryDefinition {
  id             String   @id @default(uuid())
  code           String   @unique
  label          String
  shortLabel     String?
  description    String?
  icon           String?
  displayOrder   Int      @default(0)
  featuredOrder  Int?
  isActive       Boolean  @default(true)
  showInFeatured Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  buildSequence  BuildSequence?
  categorySchema CategorySchema?
  filterConfig   CategoryFilterConfig?
  hierarchies    CategoryHierarchy[]
  categories     Category[]

  @@index([isActive, displayOrder])
  @@index([showInFeatured, featuredOrder])
}

model BuildSequence {
  id         String             @id @default(cuid())
  categoryId String             @unique
  stepOrder  Int                @unique
  category   CategoryDefinition @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([stepOrder])
}

model CategoryRelationship {
  id               String   @id @default(uuid())
  fromCategoryCode String?
  toCategoryCode   String?
  relationshipType String
  sortOrder        Int      @default(0)
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([relationshipType, sortOrder])
  @@index([fromCategoryCode])
  @@index([toCategoryCode])
}

model CategoryHierarchy {
  id                   String  @id @default(uuid())
  label                String
  categoryDefinitionId String? @map("category_definition_id")
  query                String?
  brand                String?
  parentId             String?
  sortOrder            Int     @default(0)

  categoryDefinition CategoryDefinition? @relation(fields: [categoryDefinitionId], references: [id], onDelete: SetNull)
  parent             CategoryHierarchy?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children           CategoryHierarchy[] @relation("CategoryTree")

  @@index([parentId])
  @@index([sortOrder])
  @@index([categoryDefinitionId])
}

model CategorySchema {
  id                   String   @id @default(uuid())
  categoryDefinitionId String   @unique @map("category_definition_id")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  categoryDefinition CategoryDefinition    @relation(fields: [categoryDefinitionId], references: [id], onDelete: Cascade)
  attributes         AttributeDefinition[]
}

model AttributeDefinition {
  id               String   @id @default(uuid())
  key              String
  label            String
  type             String
  required         Boolean  @default(false)
  options          String[]
  unit             String?
  categorySchemaId String
  dependencyKey    String?
  dependencyValue  String?
  sortOrder        Int      @default(0)

  categorySchema CategorySchema @relation(fields: [categorySchemaId], references: [id], onDelete: Cascade)

  @@unique([categorySchemaId, key])
}

model CategoryFilterConfig {
  id                   String   @id @default(uuid())
  categoryDefinitionId String   @unique @map("category_definition_id")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  categoryDefinition CategoryDefinition @relation(fields: [categoryDefinitionId], references: [id], onDelete: Cascade)
  filters            FilterDefinition[]

  @@index([categoryDefinitionId])
}

model FilterDefinition {
  id                     String     @id @default(uuid())
  key                    String
  label                  String
  type                   FilterType
  options                String[]
  min                    Float?
  max                    Float?
  dependencyKey          String?
  dependencyValue        String?
  sortOrder              Int        @default(0)
  categoryFilterConfigId String

  categoryFilterConfig CategoryFilterConfig @relation(fields: [categoryFilterConfigId], references: [id], onDelete: Cascade)
  values               FilterValue[]
  childDependencies    FilterDependency[]   @relation("ChildFilter")

  @@unique([categoryFilterConfigId, key])
  @@index([categoryFilterConfigId])
  @@index([categoryFilterConfigId, sortOrder])
  @@index([categoryFilterConfigId, sortOrder, key])
}

// ─────────────────────────────────────────────────
// FILTER SYSTEM — Values & Dependencies
// ─────────────────────────────────────────────────

model FilterValue {
  id                 String   @id @default(uuid())
  filterDefinitionId String
  value              String   @db.VarChar(200)
  slug               String   @db.VarChar(200)
  displayOrder       Int      @default(0)
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  filterDefinition   FilterDefinition     @relation(fields: [filterDefinitionId], references: [id], onDelete: Cascade)
  parentDependencies FilterDependency[]   @relation("ParentFilterValue")
  productAssignments ProductFilterValue[]
  productSpecs       ProductSpec[]

  @@unique([filterDefinitionId, slug])
  @@index([filterDefinitionId])
  @@index([slug])
  @@map("filter_values")
}

model FilterDependency {
  id                  String   @id @default(uuid())
  parentFilterValueId String
  childFilterId       String
  createdAt           DateTime @default(now())

  parentFilterValue FilterValue      @relation("ParentFilterValue", fields: [parentFilterValueId], references: [id], onDelete: Cascade)
  childFilter       FilterDefinition @relation("ChildFilter", fields: [childFilterId], references: [id], onDelete: Cascade)

  @@unique([parentFilterValueId, childFilterId])
  @@index([parentFilterValueId])
  @@index([childFilterId])
  @@map("filter_dependencies")
}

model ProductFilterValue {
  productId     String
  filterValueId String
  createdAt     DateTime @default(now())

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  filterValue FilterValue @relation(fields: [filterValueId], references: [id], onDelete: Cascade)

  @@id([productId, filterValueId])
  @@index([filterValueId])
  @@map("product_filter_values")
}

// ─────────────────────────────────────────────────
// CATALOG — Product, Variants, Media, Tags
// ─────────────────────────────────────────────────

model Tag {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model ProductMedia {
  id        String  @id @default(uuid())
  productId String
  url       String
  altText   String?
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sortOrder])
  @@index([productId, sortOrder])
}

model Product {
  id              String        @id @default(uuid())
  slug            String        @unique @default(uuid())
  name            String
  metaTitle       String?
  metaDescription String?
  categoryId      Int           @map("category_id")
  subcategoryId   Int?          @map("subcategory_id")
  description     String?
  status          ProductStatus @default(ACTIVE)
  deletedAt       DateTime?
  version         Int           @default(1)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category     Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory  Subcategory?         @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  specs        ProductSpec[]
  variants     ProductVariant[]
  media        ProductMedia[]
  tags         Tag[]
  filterValues ProductFilterValue[]

  @@index([status])
  @@index([brandId])
  @@index([slug])
  @@index([name])
  @@index([categoryId])
  @@index([categoryId, status, brandId])
  @@index([status, name])
}

model ProductVariant {
  id             String    @id @default(uuid())
  productId      String
  sku            String    @unique
  price          Float
  compareAtPrice Float?
  attributes     Json?
  status         String    @default("IN_STOCK")
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  buildGuideItems BuildGuideItem[]
  inventoryItems  InventoryItem[]

  @@index([productId])
  @@index([sku])
  @@index([price])
  @@index([status])
  @@index([productId, status])
  @@index([productId, price, status])
  @@index([sku, status])
}

model ProductSpec {
  id            String  @id @default(uuid())
  productId     String
  filterValueId String
  value         String
  isHighlighted Boolean @default(false)

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  filterValue FilterValue @relation(fields: [filterValueId], references: [id], onDelete: Cascade)

  @@unique([productId, filterValueId])
  @@index([filterValueId])
  @@map("product_specs")
}

// ─────────────────────────────────────────────────
// CACHING & SEARCH OPTIMIZATION
// ─────────────────────────────────────────────────

model CategoryProductCache {
  id           String   @id @default(uuid())
  categoryId   Int      @unique
  productCount Int
  minPrice     Float?
  maxPrice     Float?
  filters      Json?
  lastBuilt    DateTime @default(now())
  builtAt      DateTime @default(now())

  @@index([categoryId])
  @@map("category_product_cache")
}

model SearchSuggestion {
  id           String   @id @default(uuid())
  term         String
  categoryId   Int?
  frequency    Int      @default(1)
  lastSearched DateTime @default(now())

  @@index([term, frequency])
  @@index([categoryId, frequency])
  @@map("search_suggestions")
}

// ─────────────────────────────────────────────────
// WAREHOUSING & INVENTORY
// ─────────────────────────────────────────────────

model InventoryItem {
  id           String    @id @default(uuid())
  variantId    String
  partNumber   String?
  serialNumber String?
  quantity     Int       @default(0)
  reserved     Int       @default(0)
  reorderLevel Int       @default(5)
  costPrice    Float     @default(0)
  location     String    @default("")
  lastUpdated  DateTime?

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([quantity])
  @@index([variantId])
  @@index([variantId, location])
  @@index([location, quantity])
  @@index([lastUpdated])
}

// ─────────────────────────────────────────────────
// CUSTOMER (Guest — no auth)
// ─────────────────────────────────────────────────

model Customer {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  phone        String?
  company      String?
  addressLine1 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
  orders   Order[]

  @@index([email])
  @@index([name])
}

// ─────────────────────────────────────────────────
// ORDERS & SHIPMENTS
// ─────────────────────────────────────────────────

model Order {
  id             String       @id
  channel        SalesChannel @default(ONLINE)
  customerName   String
  email          String
  phone          String?
  date           DateTime     @default(now())
  subtotal       Float        @default(0)
  gstAmount      Float        @default(0)
  taxAmount      Float        @default(0)
  discountAmount Float        @default(0)
  total          Float
  status         OrderStatus  @default(PENDING)
  version        Int          @default(1)
  deletedAt      DateTime?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  shippingStreet  String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?

  paymentMethod        String?
  paymentTransactionId String?
  paymentStatus        String?
  paymentDueDate       DateTime?
  paymentCompletedAt   DateTime?
  paymentFailureReason String?
  idempotencyKey       String?   @unique
  source               Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      OrderItem[]
  logs       OrderLog[]
  invoices   Invoice[]
  shipments  ShipmentTracking[]
  payments   PaymentTransaction[]
  stockMoves StockMovement[]

  @@index([email])
  @@index([status])
  @@index([date])
  @@index([status, date])
  @@index([channel])
  @@index([customerId])
  @@index([paymentStatus, paymentDueDate])
  @@index([idempotencyKey, status])
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String
  variantId       String
  name            String
  categoryId      Int     @map("category_id")
  price           Float
  quantity        Int
  image           String?
  sku             String?
  variantSnapshot Json?

  order    Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  category Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([variantId])
  @@index([categoryId, orderId])
}

model OrderLog {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  timestamp DateTime    @default(now())
  note      String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, timestamp])
}

model ShipmentTracking {
  id                String    @id @default(uuid())
  orderId           String
  trackingNumber    String
  carrier           String
  status            String
  estimatedDelivery DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─────────────────────────────────────────────────
// STOCK MOVEMENTS
// ─────────────────────────────────────────────────

model StockMovement {
  id        String            @id @default(uuid())
  orderId   String?
  variantId String
  type      StockMovementType
  quantity  Int
  note      String?
  createdAt DateTime          @default(now())

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([variantId])
  @@index([type])
}

// ─────────────────────────────────────────────────
// BUILD GUIDES
// ─────────────────────────────────────────────────

model BuildGuide {
  id          String   @id @default(uuid())
  title       String
  description String?
  categoryId  Int?
  total       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items    BuildGuideItem[]
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([categoryId])
}

model BuildGuideItem {
  id           String @id @default(uuid())
  buildGuideId String
  variantId    String
  quantity     Int    @default(1)

  buildGuide BuildGuide     @relation(fields: [buildGuideId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([buildGuideId, variantId])
  @@index([buildGuideId])
}

// ─────────────────────────────────────────────────
// BILLING & INVOICES
// ─────────────────────────────────────────────────

model InvoiceSequence {
  id           String @id @default("invoice_seq")
  currentValue Int    @default(0)
}

model BillingProfile {
  id           String   @id @default(uuid())
  companyName  String
  legalName    String?
  email        String
  phone        String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String
  gstin        String?
  currency     Currency @default(INR)
  logoUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  orderId       String?
  type          InvoiceType   @default(STANDARD)
  status        InvoiceStatus @default(DRAFT)
  customerId    String
  currency      Currency      @default(INR)

  subtotal    Float @default(0)
  taxTotal    Float @default(0)
  discountPct Float @default(0)
  shipping    Float @default(0)
  total       Float @default(0)
  amountPaid  Float @default(0)
  amountDue   Float @default(0)

  notes       String?
  sentAt      DateTime?
  refundedAt  DateTime?
  cancelledAt DateTime?
  paidAt      DateTime?
  voidedAt    DateTime?

  createdAt     DateTime @default(now())
  dueDate       DateTime
  lastUpdatedAt DateTime @updatedAt

  order       Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer    Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lineItems   InvoiceLineItem[]
  audit       InvoiceAuditEvent[]
  creditNotes CreditNote[]

  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  name        String
  description String?
  quantity    Int
  unitPrice   Float
  taxRatePct  Float   @default(18)
  hsnCode     String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceAuditEvent {
  id        String   @id @default(uuid())
  invoiceId String
  type      String
  actor     String
  message   String?
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
}

// ─────────────────────────────────────────────────
// PAYMENT TRANSACTIONS
// ─────────────────────────────────────────────────

model PaymentTransaction {
  id             String            @id @default(uuid())
  orderId        String
  method         PaymentMethodType
  gatewayTxnId   String?           @unique
  amount         Float
  currency       Currency          @default(INR)
  status         PaymentStatus     @default(INITIATED)
  idempotencyKey String            @unique
  metadata       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order    Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  attempts PaymentAttempt[]

  @@index([orderId])
  @@index([status])
}

model PaymentAttempt {
  id              String        @id @default(uuid())
  paymentTxnId    String
  attemptNumber   Int
  status          PaymentStatus
  gatewayResponse Json?
  errorMessage    String?
  createdAt       DateTime      @default(now())

  transaction PaymentTransaction @relation(fields: [paymentTxnId], references: [id], onDelete: Cascade)

  @@index([paymentTxnId, attemptNumber])
  @@map("payment_attempts")
}

// ─────────────────────────────────────────────────
// CREDIT NOTES
// ─────────────────────────────────────────────────

model CreditNote {
  id                String  @id @default(uuid())
  creditNoteNumber  String  @unique
  originalInvoiceId String
  orderId           String?
  reason            String
  subtotal          Float
  taxTotal          Float
  total             Float

  createdAt DateTime @default(now())

  originalInvoice Invoice              @relation(fields: [originalInvoiceId], references: [id], onDelete: Restrict)
  lineItems       CreditNoteLineItem[]

  @@index([originalInvoiceId])
  @@index([orderId])
}

model CreditNoteLineItem {
  id           String  @id @default(uuid())
  creditNoteId String
  name         String
  quantity     Int
  unitPrice    Float
  taxRatePct   Float   @default(18)
  hsnCode      String?

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}

// ─────────────────────────────────────────────────
// UNIFIED AUDIT LOG
// ─────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  actor      String   @default("System")
  changes    Json?
  before     Json?
  after      Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actor])
  @@index([entityType, createdAt(sort: Desc)])
  @@index([actor, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}
