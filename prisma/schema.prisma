// e:\web-dev\pc-system\md_client\prisma\schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// UPGRADED PROJECT A

// ─────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SpecValueType {
  STRING
  NUMBER
  BOOLEAN
}

enum CompatibilityOperator {
  EQUAL
  NOT_EQUAL
  LESS_THAN
  LESS_OR_EQUAL
  GREATER_THAN
  GREATER_OR_EQUAL
  IN_LIST
  CONTAINS
}

enum CompatibilitySeverity {
  ERROR
  WARNING
  INFO
}

enum InventoryUnitStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

// ─────────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────
// LAYER 1: Core Catalog
// ─────────────────────────────────────────────────

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  slug        String  @unique

  subCategories SubCategory[]
  brands        Brand[]
  products      Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubCategory {
  id          String  @id @default(uuid())
  name        String
  description String?
  slug        String  @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  products        Product[]
  specDefinitions SpecDefinition[]

  sourceRules CompatibilityRule[] @relation("sourceSubCategory")
  targetRules CompatibilityRule[] @relation("targetSubCategory")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, name])
}

model Brand {
  id         String     @id @default(uuid())
  name       String     @unique
  categories Category[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  products   Product[]
}

model Tag {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model ProductMedia {
  id        String  @id @default(uuid())
  productId String
  url       String
  altText   String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sortOrder])
  @@index([productId, sortOrder])
}

model Product {
  id              String  @id @default(uuid())
  slug            String  @unique @default(uuid())
  name            String
  metaTitle       String?
  metaDescription String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  subCategoryId String
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)

  description String?
  status      ProductStatus @default(ACTIVE)
  deletedAt   DateTime?
  version     Int           @default(1)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]
  media    ProductMedia[]
  tags     Tag[]

  @@index([status])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([brandId])
  @@index([slug])
  @@index([name])
  @@index([status, categoryId])
  @@index([status, subCategoryId])
  @@index([status, name])
}

model ProductVariant {
  id             String    @id @default(uuid())
  productId      String
  sku            String    @unique
  price          Float
  compareAtPrice Float?
  status         String    @default("IN_STOCK")
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryUnits InventoryUnit[]
  specs          VariantSpec[]

  @@index([productId])
  @@index([sku])
  @@index([price])
  @@index([status])
  @@index([productId, status])
  @@index([productId, price])
}

// ─────────────────────────────────────────────────
// LAYER 2: Spec System
// ─────────────────────────────────────────────────

model SpecDefinition {
  id String @id @default(uuid())

  subCategoryId String
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  name      String
  slug      String?
  label     String?
  valueType SpecValueType

  isRequired   Boolean @default(false)
  isFilterable Boolean @default(true)
  isVisible    Boolean @default(true)
  isRange      Boolean @default(false)
  isMulti      Boolean @default(false)

  filterGroup String?
  filterOrder Int?

  options SpecOption[]

  variantSpecs VariantSpec[]

  parentOptionDeps SpecOptionDependency[] @relation("SOD_ParentSpec")
  childOptionDeps  SpecOptionDependency[] @relation("SOD_ChildSpec")

  sourceRules CompatibilityRule[] @relation("ruleSource")
  targetRules CompatibilityRule[] @relation("ruleTarget")

  @@unique([subCategoryId, name])
}

model SpecOption {
  id String @id @default(uuid())

  specId String
  spec   SpecDefinition @relation(fields: [specId], references: [id], onDelete: Cascade)

  value String
  label String?

  order Int?

  parentOptionId String?
  parentOption   SpecOption?  @relation("OptionTree", fields: [parentOptionId], references: [id])
  children       SpecOption[] @relation("OptionTree")

  variantSpecs VariantSpec[]

  parentOptionDeps SpecOptionDependency[] @relation("SOD_ParentOption")
  childOptionDeps  SpecOptionDependency[] @relation("SOD_ChildOption")

  @@unique([specId, value])
}

model SpecOptionDependency {
  id String @id @default(uuid())

  parentSpecId   String
  parentOptionId String

  childSpecId   String
  childOptionId String?

  parentSpec   SpecDefinition @relation("SOD_ParentSpec", fields: [parentSpecId], references: [id], onDelete: Cascade)
  parentOption SpecOption     @relation("SOD_ParentOption", fields: [parentOptionId], references: [id], onDelete: Cascade)

  childSpec   SpecDefinition @relation("SOD_ChildSpec", fields: [childSpecId], references: [id], onDelete: Cascade)
  childOption SpecOption?    @relation("SOD_ChildOption", fields: [childOptionId], references: [id], onDelete: Cascade)

  @@unique([parentSpecId, parentOptionId, childSpecId, childOptionId])
  @@index([parentSpecId, parentOptionId])
}

model VariantSpec {
  id String @id @default(uuid())

  variantId String
  specId    String

  optionId String?

  valueString String?
  valueNumber Float?
  valueBool   Boolean?

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  spec    SpecDefinition @relation(fields: [specId], references: [id], onDelete: Cascade)
  option  SpecOption?    @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([variantId, specId])
  @@index([variantId])
  @@index([specId, optionId])
}

// ─────────────────────────────────────────────────
// LAYER 3: Compatibility Engine
// ─────────────────────────────────────────────────

model CompatibilityRule {
  id String @id @default(uuid())

  name String

  sourceSubCategoryId String
  targetSubCategoryId String

  sourceSubCategory SubCategory @relation("sourceSubCategory", fields: [sourceSubCategoryId], references: [id], onDelete: Cascade)
  targetSubCategory SubCategory @relation("targetSubCategory", fields: [targetSubCategoryId], references: [id], onDelete: Cascade)

  sourceSpecId String
  targetSpecId String

  operator CompatibilityOperator

  message  String
  severity CompatibilitySeverity
  priority Int                   @default(0)

  sourceSpec SpecDefinition @relation("ruleSource", fields: [sourceSpecId], references: [id], onDelete: Cascade)
  targetSpec SpecDefinition @relation("ruleTarget", fields: [targetSpecId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────
// LAYER 4: Inventory Engine
// ─────────────────────────────────────────────────

model InventoryUnit {
  id           String              @id @default(uuid())
  variantId    String
  serialNumber String?             @unique
  status       InventoryUnitStatus @default(AVAILABLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  reservation Reservation?

  @@index([variantId])
  @@index([status])
}

model Reservation {
  id              String   @id @default(uuid())
  inventoryUnitId String   @unique
  expiresAt       DateTime

  inventoryUnit InventoryUnit @relation(fields: [inventoryUnitId], references: [id], onDelete: Cascade)
}
